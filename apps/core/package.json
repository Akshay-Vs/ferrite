{
	"name": "@ferrite/core",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"scripts": {
		"build": "nest build && tsc-alias -p tsconfig.json",
		"format": "biome format --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/src/main",
		"lint": "biome check --fix \"{src,apps,libs,test}/**/*.ts\"",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio --verbose"
	},
	"dependencies": {
		"@clerk/backend": "^2.33.0",
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/cache-manager": "^3.1.0",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/throttler": "^6.5.0",
		"@willsoto/nestjs-prometheus": "^6.0.2",
		"bullmq": "^5.70.4",
		"dotenv": "^17.3.1",
		"drizzle": "^1.4.0",
		"drizzle-orm": "^0.45.1",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"nestjs-zod": "^5.1.1",
		"pino": "^10.3.1",
		"postgres": "^3.4.8",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"svix": "^1.86.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"drizzle-kit": "^0.31.9",
		"jest": "^30.0.0",
		"nestjs-spelunker": "^1.3.2",
		"pino-pretty": "^13.1.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
