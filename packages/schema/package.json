{
	"name": "@ferrite/schema",
	"version": "0.0.1",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"tsup": "^8.5.1",
		"typescript": "^6"
	},
	"dependencies": {
		"zod": "^4.4.1"
	},
	"peerDependencies": {
		"typescript": "^6"
	},
	"private": true,
	"type": "module"
}
