{
	"name": "@ferrite/api",
	"version": "0.0.1",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@ferrite/schema": "workspace:*",
		"axios": "^1.9.0",
		"zod": "^4.4.1"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"tsup": "^8.5.1",
		"typescript": "^6"
	}
}
